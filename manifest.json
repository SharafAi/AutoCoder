{
  "manifest_version": 3,
  "name": "AutoCoder",
  "version": "1.0",
  "description": "Professional container automation tool.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "AutoCoder",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "config.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}